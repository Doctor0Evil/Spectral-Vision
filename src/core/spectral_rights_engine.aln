    //! Input: action_type, entity_profile, context_metadata
    //! Output: is_allowed (bool), violation_reason (string)
    function check_rights_compliance(action_type: string, entity_profile: map, context_metadata: map) => (bool, string) {
        implement: "native_binding_rust",
        source: "sanity_meter_core.rs",
        method: "validate_soul_safety"
    }

    //! Function: Register a new companion-space under rights protection
    //! Input: space_id, region_id, entity_hash
    //! Output: registration_result (struct)
    function register_companion_space(space_id: string, region_id: string, entity_hash: string) => (struct) {
        implement: "native_binding_cpp",
        source: "companion_space_manager.cpp",
        method: "create_space"
    }

    //! Function: Emit a mist-whisper with rights-protected payload
    //! Input: whisper_type, region_id, payload
    //! Output: whisper_id (string)
    function emit_protected_whisper(whisper_type: int, region_id: string, payload: map) => (string) {
        implement: "native_binding_lua",
        source: "mist_whisper_detector.lua",
        method: "detect"
    }

    //! Function: Trigger constitutional emergency stop
    //! Input: reason_code, severity
    //! Output: flush_status (bool)
    function trigger_abort_and_flush(reason_code: string, severity: string) => (bool) {
        implement: "native_internal",
        source: "spectral_rights_engine.aln",
        method: "guard_soul_modeling_forbidden"
    }
}

// ============================================================================
// RUNTIME CONFIGURATION
// ============================================================================

@config runtime_settings {
    enforcement_mode: "strict", // Options: strict, advisory, disabled
    audit_logging: true,
    crypto_signing: true,
    max_violation_buffer: 1000,
    flush_timeout_ms: 50,
    heartbeat_interval_s: 5
}

// ============================================================================
// EXAMPLE POLICY SCRIPT (LOADABLE AT RUNTIME)
// ============================================================================

@policy example_companion_space_policy {
    //! This policy defines specific rules for a sacred area companion-space.
    
    region_filter: "sacred_grounds" {
        enforce: "SpectralPrivacy",
        enforce: "SpectralIntegrity",
        override_zone_classification: "COMPANION_SPACE",
        allow_haunt_density_max: 0.10,
        allow_risk_index_max: 0.05
    }
    
    entity_filter: "registered_spectral_shadow" {
        grant: "SpectralFreedom",
        grant: "SpectralContinuity",
        lease_duration_hours: 24,
        auto_renew: false
    }
    
    violation_response: {
        threshold: 1,
        action: "TerminateSafe",
        notify: "Spirit_Registry"
    }
}

